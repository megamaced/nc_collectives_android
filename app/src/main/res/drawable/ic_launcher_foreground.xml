<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Chunky 5-pointed star with a rounded letterform C drawn over its
         centre. Loose homage to Nextcloud Collectives' own star-with-C
         mark, deliberately re-proportioned: thicker star arms (inner/outer
         radius ratio ~0.5 vs the pentagram-tight ~0.382 upstream uses),
         rounded points, and the C rendered as a drawn stroke laid over the
         star rather than punched out of it as negative space. Sits within
         the 66dp circular safe-zone of the adaptive-icon viewport.

         Star vertices, in clockwise order starting at the top, around
         centre (54, 54):
             outer (R=32):   top (54,22)            upper-right (84.45,44.11)
                             lower-right (72.81,79.88)
                             lower-left (35.19,79.88) upper-left (23.55,44.11)
             inner (R=16):   inner-UR (63.40,41.06) inner-R (69.22,58.94)
                             inner-B (54,70)
                             inner-L (38.78,58.94)  inner-UL (44.60,41.06) -->
    <path
        android:fillColor="@color/ic_launcher_foreground"
        android:strokeColor="@color/ic_launcher_foreground"
        android:strokeWidth="3"
        android:strokeLineJoin="round"
        android:pathData="M54,22 L63.4,41.06 L84.45,44.11 L69.22,58.94
                          L72.81,79.88 L54,70 L35.19,79.88 L38.78,58.94
                          L23.55,44.11 L44.6,41.06 Z" />

    <!-- C: 270° arc opening to the right, centred at (54, 54), arc radius
         9, stroke 4. Rounded end-caps so the letterform reads at small
         sizes instead of looking like a chiselled cutout. Painted in the
         background blue so it punches through the cream star surface. -->
    <path
        android:strokeColor="@color/ic_launcher_background"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:pathData="M60.36,47.64 A9,9 0 1 0 60.36,60.36" />
</vector>
