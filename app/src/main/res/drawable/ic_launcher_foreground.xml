<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Open notebook: two facing parchment pages with a slight perspective tilt
         (top edges sweep outward, bottom edges sweep outward) so the V-shaped
         spine reads as "open book" at small sizes. Stays within the 66dp
         circular safe-zone of the adaptive-icon viewport. -->

    <!-- Left page -->
    <path
        android:fillColor="@color/ic_launcher_foreground"
        android:pathData="M27,40 L54,44 L54,78 L27,74 Z" />

    <!-- Right page -->
    <path
        android:fillColor="@color/ic_launcher_foreground"
        android:pathData="M54,44 L81,40 L81,74 L54,78 Z" />

    <!-- Spine where the pages meet -->
    <path
        android:strokeColor="@color/ic_launcher_background"
        android:strokeWidth="1.0"
        android:strokeLineCap="round"
        android:pathData="M54,44 L54,78" />

    <!-- Text lines on the left page -->
    <path
        android:strokeColor="@color/ic_launcher_background"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:pathData="M33,51 L48,53
                          M33,57 L48,59
                          M33,63 L48,65
                          M33,69 L45,70" />

    <!-- Text lines on the right page -->
    <path
        android:strokeColor="@color/ic_launcher_background"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:pathData="M60,53 L75,51
                          M60,59 L75,57
                          M60,65 L75,63
                          M63,70 L75,69" />
</vector>
