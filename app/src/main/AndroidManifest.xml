<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!--
        POST_NOTIFICATIONS is the runtime-prompt permission for Android 13+;
        below 13 it's auto-granted. UpdateChecker.postNotification() guards
        the actual `notify` call with a checkSelfPermission() on Tiramisu+
        so the app never prompts the user — they grant it (or don't) from
        the system settings. Declaring it here lets lint know the call site
        is intentional and silences MissingPermission / NotificationPermission.
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
        CAMERA isn't strictly required: we launch the system camera via
        ACTION_IMAGE_CAPTURE through a FileProvider URI, which the OS
        already grants to the chosen camera app. Declaring the feature
        as optional keeps the install footprint right on devices without
        a camera.
    -->
    <uses-feature
        android:name="android.hardware.camera.any"
        android:required="false" />

    <application
        android:name=".NcCollectivesApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NcCollectives"
        tools:targetApi="36">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.NcCollectives.Splash"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
                Share-target entry. The system share sheet shows
                "NC Collectives" with the adaptive icon; users can pipe in
                a URL/snippet from a browser or a photo from the gallery.
                ACTION_PROCESS_TEXT exposes a "share-as-selection" entry
                in text editors / browsers on API 23+.
            -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <!--
                S-11: image share filters restrict to content:// URIs so
                the OS only routes senders that hand off a real content
                provider URI. SharePayload.fromIntent does a second-line
                filter that drops anything that slipped past (e.g. an app
                bypassing the system share sheet to target the Activity
                directly).
            -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
                <data android:scheme="content" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
                <data android:scheme="content" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <!-- Hilt configures WorkManager with the custom worker factory in
                 NcCollectivesApplication, so disable WorkManager's automatic
                 startup initializer. -->
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
